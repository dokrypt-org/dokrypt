[profile.default]
src = "contracts"
out = "out"
libs = ["lib"]
test = "test"
solc_version = "0.8.20"
optimizer = true
optimizer_runs = 200
via_ir = false
evm_version = "paris"
gas_reports = ["*"]

[profile.default.fuzz]
runs = 256
max_test_rejects = 65536
seed = "0x1"

[profile.ci]
fuzz = { runs = 10000 }

[fmt]
line_length = 120
tab_width = 4
bracket_spacing = false
int_types = "long"
multiline_func_header = "attributes_first"
quote_style = "double"
number_underscore = "thousands"

[rpc_endpoints]
localhost = "http://127.0.0.1:8545"
arbitrum = "${ARBITRUM_RPC_URL}"
mainnet = "${MAINNET_RPC_URL}"
