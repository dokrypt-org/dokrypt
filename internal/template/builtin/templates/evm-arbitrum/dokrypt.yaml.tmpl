name: {{ .ProjectName }}
version: "1.0"

chains:
  {{ .ChainName }}:
    engine: {{ .Engine }}
    chain_id: {{ .ChainID }}
    block_time: 1s
    accounts: 10
    balance: "10000000000000000000000"
    fork:
      enabled: true
      network: arbitrum-mainnet
      chain_id: 42161

services:
  explorer:
    type: blockscout
    depends_on:
      - {{ .ChainName }}
  monitor:
    type: prometheus
    depends_on:
      - {{ .ChainName }}
